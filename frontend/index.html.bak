<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BookMyShoot | Professional Photography Studio</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
</head>

<body>

  <!-- NAVBAR -->
  <header class="navbar" id="mainNavbar">
    <div class="logo"><a href="index.html">BookMyShoot</a></div>
    <div class="menu-toggle" id="menuToggle" onclick="toggleMobileMenu()">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <nav id="mainNav">
      <a href="index.html" class="active">Home</a>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#portfolio">Portfolio</a>
      <a href="contact.html">Contact</a>
      <div class="nav-auth" id="authNav"></div>
    </nav>
  </header>

  <!-- HERO (Logged in) -->
  <section class="hero" id="profileSection" style="display:none;">
    <h1>Welcome back, <span id="profileName"></span>!</h1>
    <p>Your account is ready for bookings</p>
    <button onclick="window.location.href='booking.html'">Book a Session</button>
  </section>

  <!-- HERO (Guest) -->
  <section class="hero" id="guestHero">
    <h1>Capture Your Moments in Premium Style</h1>
    <p>Wedding • Engagement • Baby Shower • Birthdays • Studio Sessions</p>
    <button onclick="window.location.href='booking.html'">Book a Session</button>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="about-content">
      <div class="about-left">
        <h2>About BookMyShoot</h2>
        <div class="line"></div>
        <p>
          BookMyShoot is a premium studio and photographer booking system designed to
          simplify event photography reservations. Customers can browse services,
          book sessions, and manage their appointments with ease.
        </p>
        <p>
          We specialize in capturing life's most precious moments with style and elegance.
          From intimate wedding ceremonies to vibrant birthday celebrations, our
          expert photographers create stunning visual memories that last forever.
        </p>
        <a href="#services" class="about-cta">Explore Our Services</a>
      </div>
      <div class="about-right">
        <div class="about-stats">
          <div class="stat-item">
            <span class="stat-number">500+</span>
            <span class="stat-label">Sessions Completed</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">50+</span>
            <span class="stat-label">Professional Photographers</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Customer Satisfaction</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">24/7</span>
            <span class="stat-label">Customer Support</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <h2>Our Services</h2>
    <p class="section-subtitle">Choose from our range of professional photography services</p>
    <div class="service-grid">
      <a href="services/wedding.html" class="card">
        <span class="card-icon">💒</span>
        <span class="card-title">Wedding Photoshoot</span>
        <span class="card-desc">Capture your special day with stunning wedding photography</span>
      </a>
      <a href="services/engagement.html" class="card">
        <span class="card-icon">💍</span>
        <span class="card-title">Engagement Shoot</span>
        <span class="card-desc">Beautiful pre-wedding engagement photography</span>
      </a>
      <a href="services/naming.html" class="card">
        <span class="card-icon">👶</span>
        <span class="card-title">Naming Ceremony</span>
        <span class="card-desc">Precious moments of your little one's special day</span>
      </a>
      <a href="services/birthday.html" class="card">
        <span class="card-icon">🎂</span>
        <span class="card-title">Birthday Events</span>
        <span class="card-desc">Fun and memorable birthday party photography</span>
      </a>
      <a href="services/babyshower.html" class="card">
        <span class="card-icon">🍼</span>
        <span class="card-title">Baby Shower</span>
        <span class="card-desc">Celebrate the upcoming arrival with beautiful photos</span>
      </a>
      <a href="services/studio.html" class="card">
        <span class="card-icon">📸</span>
        <span class="card-title">Studio Sessions</span>
        <span class="card-desc">Professional studio portraits and headshots</span>
      </a>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="portfolio" id="portfolio">
    <div class="container">
      <h2>Our Portfolio</h2>
      <p class="section-subtitle">A glimpse of our recent work</p>
      <div class="portfolio-grid">
        <div class="portfolio-item reveal" onclick="window.location.href='services/wedding.html'">
          <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800&h=600&fit=crop"
            alt="Wedding Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.1</div>
            <h3>Wedding Moments</h3>
          </div>
        </div>
        <div class="portfolio-item reveal" onclick="window.location.href='services/studio.html'">
          <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=800&h=600&fit=crop"
            alt="Portrait Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.2</div>
            <h3>Portrait Sessions</h3>
          </div>
        </div>
        <div class="portfolio-item reveal" onclick="window.location.href='services/birthday.html'">
          <img src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=800&h=600&fit=crop"
            alt="Event Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.3</div>
            <h3>Special Events</h3>
          </div>
        </div>
        <div class="portfolio-item reveal" onclick="window.location.href='services/engagement.html'">
          <img src="https://images.unsplash.com/photo-1515934751635-c81c6bc9a2d8?w=800&h=600&fit=crop"
            alt="Engagement Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.4</div>
            <h3>Engagement Shoots</h3>
          </div>
        </div>
        <div class="portfolio-item reveal" onclick="window.location.href='services/babyshower.html'">
          <img src="https://images.unsplash.com/photo-1519817914152-22d216bb9170?w=800&h=600&fit=crop"
            alt="Baby Shower Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.5</div>
            <h3>Baby Showers</h3>
          </div>
        </div>
        <div class="portfolio-item reveal" onclick="window.location.href='services/studio.html'">
          <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=800&h=600&fit=crop"
            alt="Studio Photography">
          <div class="portfolio-meta">
            <div class="small">Album No.6</div>
            <h3>Studio Portraits</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE BAND -->
  <section class="feature-band reveal">
    <div class="container">
      <h2>Let's Create Beautiful Memories Together!</h2>
      <p class="lead">Book your session today and let us turn your special moments into timeless art.</p>
      <a href="booking.html" class="feature-cta">Book Now</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="contact-header reveal">
      <h2>Let's Talk</h2>
      <p class="section-subtitle">Have questions? We'd love to hear from you!</p>
    </div>
    <form id="contactForm" class="reveal">
      <div class="form-group-minimal">
        <input type="text" placeholder="First Name" required>
      </div>
      <div class="form-group-minimal">
        <input type="text" placeholder="Last Name" required>
      </div>
      <div class="form-group-minimal">
        <input type="email" placeholder="Email" required>
      </div>
      <div class="form-group-minimal">
        <input type="text" placeholder="Subject">
      </div>
      <div class="form-group-minimal full-width">
        <textarea placeholder="Message"></textarea>
      </div>
      <button type="submit" class="contact-btn">Send Message</button>
    </form>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-content">
      <div class="footer-logo">BookMyShoot</div>
      <div class="footer-links">
        <a href="index.html">Home</a>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="contact.html">Contact</a>
      </div>
      <div class="footer-social">
        <a href="#">📘</a>
        <a href="#">📸</a>
        <a href="#">🐦</a>
      </div>
    </div>
    <div class="footer-bottom">
      © 2026 BookMyShoot | BCA Final Project
      <br>Developed by Navajith C S
    </div>
  </footer>

  <script src="js/main.js"></script>
  <script>
    // Initialize auth on page load
    document.addEventListener('DOMContentLoaded', function () {
      initAuth();
      initContactForm();
      initSmoothScroll();
    });

    function initAuth() {
      const user = JSON.parse(localStorage.getItem('user') || 'null');

      // Redirect Admin to Dashboard
      if (user && user.user_type === 'admin') {
        window.location.href = 'admin-dashboard.html';
        return;
      }

      // Redirect Photographer to their Dashboard
      if (user && user.user_type === 'photographer') {
        window.location.href = 'photographer-dashboard.html';
        return;
      }

      const authNav = document.getElementById('authNav');

      if (user) {
        // Show profile section, hide guest hero
        document.getElementById('profileSection').style.display = 'flex';
        document.getElementById('guestHero').style.display = 'none';
        document.getElementById('profileName').textContent = user.first_name;

        authNav.innerHTML = `
        <a href="#" class="user-btn" onclick="showProfile(); return false;">👤 ${user.first_name}</a>
        <a href="#" class="logout-btn" onclick="logout(); return false;">Logout</a>
      `;
      } else {
        authNav.innerHTML = `
        <a href="login.html" class="login-btn">Login</a>
        <a href="register.html" class="register-btn">Sign Up</a>
      `;
      }
    }

    function initContactForm() {
      const contactForm = document.getElementById('contactForm');
      if (contactForm) {
        contactForm.addEventListener('submit', function (e) {
          e.preventDefault();
          alert('Thank you for your message! We will get back to you soon.');
          this.reset();
        });
      }
    }

    function initSmoothScroll() {
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            // Close mobile menu if open
            document.getElementById('mainNav').classList.remove('active');
            document.getElementById('menuToggle').classList.remove('active');

            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    function toggleMobileMenu() {
      const nav = document.getElementById('mainNav');
      const toggle = document.getElementById('menuToggle');
      nav.classList.toggle('active');
      toggle.classList.toggle('active');
    }
  </script>
</body>

</html>