<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders — BookMyShoot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="css/style.css">
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
    }

    .dashboard-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 30px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .dashboard-header h1 {
      font-size: 1.8rem;
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .user-avatar {
      width: 45px;
      height: 45px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
    }

    .logout-btn {
      background: rgba(255, 255, 255, 0.2);
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.3s;
    }

    .logout-btn:hover {
      background: rgba(255, 255, 255, 0.3);
    }

    .dashboard-container {
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .quick-actions {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .action-card {
      background: white;
      border-radius: 16px;
      padding: 25px;
      text-align: center;
      text-decoration: none;
      color: #1a1a1a;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      transition: all 0.3s;
    }

    .action-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    }

    .action-card .icon {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .action-card h3 {
      font-size: 1.1rem;
      margin-bottom: 5px;
    }

    .action-card p {
      font-size: 0.85rem;
      color: #666;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 25px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: white;
      border-radius: 16px;
      padding: 25px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .stat-card h3 {
      color: #666;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 10px;
    }

    .stat-card .value {
      font-size: 1.8rem;
      font-weight: 700;
      color: #1a1a1a;
    }

    .stat-card.pending .value {
      color: #f59e0b;
    }

    .stat-card.paid .value {
      color: #10b981;
    }

    .section-title {
      font-size: 1.3rem;
      font-weight: 600;
      margin-bottom: 20px;
      color: #1a1a1a;
    }

    .orders-grid {
      display: grid;
      gap: 20px;
    }

    .order-card {
      background: white;
      border-radius: 16px;
      padding: 25px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .order-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 15px;
    }

    .order-id {
      font-size: 0.85rem;
      color: #666;
    }

    .order-status {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .order-status.new {
      background: #e0e7ff;
      color: #3730a3;
    }

    .order-status.pending {
      background: #fef3c7;
      color: #92400e;
    }

    .order-status.accepted {
      background: #d1fae5;
      color: #065f46;
    }

    .order-status.completed {
      background: #dbeafe;
      color: #1e40af;
    }

    .order-details {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }

    .detail-item label {
      display: block;
      font-size: 0.8rem;
      color: #666;
      margin-bottom: 4px;
    }

    .detail-item span {
      font-weight: 500;
      color: #1a1a1a;
    }

    .payment-section {
      background: #f9fafb;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
    }

    .payment-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    .payment-row.total {
      font-weight: 700;
      font-size: 1.2rem;
      padding-top: 10px;
      border-top: 1px solid #e5e5e5;
    }

    .payment-status {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .payment-status.paid {
      background: #d1fae5;
      color: #065f46;
    }

    .payment-status.unpaid {
      background: #fee2e2;
      color: #991b1b;
    }

    .btn {
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      border: none;
      font-size: 0.95rem;
    }

    .btn-pay {
      background: #10b981;
      color: white;
    }

    .btn-pay:hover {
      background: #059669;
    }

    .empty-state {
      background: white;
      border-radius: 16px;
      padding: 50px;
      text-align: center;
    }

    .empty-state h3 {
      color: #1a1a1a;
      margin-bottom: 10px;
    }

    .empty-state p {
      color: #666;
      margin-bottom: 20px;
    }

    .empty-state a {
      display: inline-block;
      padding: 12px 30px;
      background: #667eea;
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
    }

    /* Notification Styles */
    .notification-btn {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      position: relative;
      transition: all 0.3s;
    }

    .notification-btn:hover {
      transform: scale(1.1);
    }

    .notification-badge {
      position: absolute;
      top: -8px;
      right: -8px;
      background: #ef4444;
      color: white;
      border-radius: 50%;
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .notification-panel {
      display: none;
      position: fixed;
      top: 70px;
      right: 20px;
      width: 380px;
      max-height: 500px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
      z-index: 1000;
      overflow-y: auto;
    }

    .notification-panel.open {
      display: block;
      animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .notification-header {
      padding: 15px 20px;
      border-bottom: 1px solid #e5e5e5;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .notification-header h3 {
      margin: 0;
      font-size: 1rem;
      color: #1a1a1a;
    }

    .clear-btn {
      background: none;
      border: 1px solid #ddd;
      padding: 4px 12px;
      border-radius: 6px;
      font-size: 0.8rem;
      cursor: pointer;
      color: #666;
      transition: all 0.3s;
    }

    .clear-btn:hover {
      background: #f9fafb;
      border-color: #ccc;
    }

    .notification-list {
      padding: 0;
      margin: 0;
      list-style: none;
    }

    .notification-item {
      padding: 15px 20px;
      border-bottom: 1px solid #f0f0f0;
      transition: all 0.3s;
      cursor: pointer;
    }

    .notification-item:hover {
      background: #f9fafb;
    }

    .notification-item.unread {
      background: #f0f4ff;
      border-left: 3px solid #667eea;
    }

    .notification-item.unread:hover {
      background: #e8ecff;
    }

    .notification-item.job-accepted {
      border-left: 3px solid #10b981;
    }

    .notification-item.job-declined {
      border-left: 3px solid #ef4444;
    }

    .notification-title {
      font-weight: 600;
      color: #1a1a1a;
      margin-bottom: 5px;
      font-size: 0.95rem;
    }

    .notification-message {
      color: #666;
      font-size: 0.85rem;
      margin-bottom: 5px;
    }

    .notification-time {
      font-size: 0.75rem;
      color: #999;
    }

    .notification-empty {
      padding: 40px 20px;
      text-align: center;
      color: #999;
    }

    .backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.3);
      z-index: 999;
    }

    .backdrop.open {
      display: block;
    }
  </style>
</head>

<body>
  <div class="backdrop" id="notificationBackdrop"></div>

  <header class="dashboard-header">
    <h1><i class="bi bi-receipt-cutoff" style="margin-right:10px;"></i>My Orders</h1>
    <div class="user-info">
      <button class="notification-btn" id="notificationBtn" title="Notifications">
        <i class="bi bi-bell-fill"></i>
        <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
      </button>
      <div class="notification-panel" id="notificationPanel">
        <div class="notification-header">
          <h3>Notifications</h3>
          <button class="clear-btn" onclick="clearAllNotifications()">Clear All</button>
        </div>
        <ul class="notification-list" id="notificationList">
          <li class="notification-empty">No notifications yet</li>
        </ul>
      </div>
      <div class="user-avatar" id="userAvatar">C</div>
      <span id="customerName">Customer</span>
      <button class="logout-btn" onclick="logout()">Logout</button>
    </div>
  </header>

  <div class="dashboard-container">
    <div class="quick-actions">
      <a href="booking.html" class="action-card">
        <div class="icon"><i class="bi bi-camera-fill" style="font-size:2.5rem;color:#667eea;"></i></div>
        <h3>Book a Session</h3>
        <p>Book a photographer for your event</p>
      </a>
      <a href="index.html" class="action-card">
        <div class="icon"><i class="bi bi-house-fill" style="font-size:2.5rem;color:#667eea;"></i></div>
        <h3>Home</h3>
        <p>Go to homepage</p>
      </a>
    </div>

    <div class="stats-grid">
      <div class="stat-card pending">
        <h3>Pending Bookings</h3>
        <div class="value" id="pendingCount">0</div>
      </div>
      <div class="stat-card paid">
        <h3>Active Bookings</h3>
        <div class="value" id="activeCount">0</div>
      </div>
      <div class="stat-card">
        <h3>Completed</h3>
        <div class="value" id="completedCount">0</div>
      </div>
      <div class="stat-card">
        <h3>Total Spent</h3>
        <div class="value" id="totalSpent">₹0</div>
      </div>
    </div>

    <h2 class="section-title">My Bookings</h2>
    <div id="ordersContainer" class="orders-grid">
      <!-- Orders will be loaded here -->
    </div>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    // API Base URL
    const API_URL = 'http://localhost:5000/api';

    // Check if user is logged in as customer
    const user = JSON.parse(localStorage.getItem('user') || '{}');

    if (!user.user_type || user.user_type !== 'customer') {
      window.location.href = 'login.html';
    }

    // Display user info
    document.getElementById('customerName').textContent = user.first_name || 'Customer';
    document.getElementById('userAvatar').textContent = (user.first_name || 'C').charAt(0).toUpperCase();

    // Notification Management
    const notificationBtn = document.getElementById('notificationBtn');
    const notificationPanel = document.getElementById('notificationPanel');
    const notificationBackdrop = document.getElementById('notificationBackdrop');
    let notificationsOpen = false;

    // Toggle notification panel
    notificationBtn.addEventListener('click', () => {
      notificationsOpen = !notificationsOpen;
      notificationPanel.classList.toggle('open');
      notificationBackdrop.classList.toggle('open');
      if (notificationsOpen) {
        loadNotifications();
      }
    });

    // Close notification panel when clicking backdrop
    notificationBackdrop.addEventListener('click', () => {
      notificationsOpen = false;
      notificationPanel.classList.remove('open');
      notificationBackdrop.classList.remove('open');
    });

    // Load notifications from API
    async function loadNotifications() {
      try {
        const response = await fetch(`${API_URL}/notifications/user/${user.id}?limit=10`, {
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (response.ok) {
          const data = await response.json();
          const notifications = data.notifications || [];
          const unreadCount = data.unread_count || 0;

          displayNotifications(notifications);
          updateNotificationBadge(unreadCount);
        }
      } catch (error) {
        console.error('Error loading notifications:', error);
      }
    }

    // Display notifications in the panel
    function displayNotifications(notifications) {
      const notificationList = document.getElementById('notificationList');

      if (notifications.length === 0) {
        notificationList.innerHTML = '<li class="notification-empty">No notifications yet</li>';
        return;
      }

      notificationList.innerHTML = notifications.map(notif => {
        const date = new Date(notif.created_at);
        const timeStr = formatTime(date);
        const unreadClass = notif.is_read ? '' : 'unread';
        const typeClass = notif.notification_type.replace(/_/g, '-');

        return `
          <li class="notification-item ${unreadClass} ${typeClass}" onclick="markNotificationRead(${notif.id})">
            <div class="notification-title">${notif.title}</div>
            <div class="notification-message">${notif.message}</div>
            <div class="notification-time">${timeStr}</div>
          </li>
        `;
      }).join('');
    }

    // Format time for notifications
    function formatTime(date) {
      const now = new Date();
      const diff = now - date;
      const minutes = Math.floor(diff / 60000);
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);

      if (minutes < 1) return 'Just now';
      if (minutes < 60) return `${minutes}m ago`;
      if (hours < 24) return `${hours}h ago`;
      if (days < 7) return `${days}d ago`;

      return date.toLocaleDateString();
    }

    // Update notification badge
    function updateNotificationBadge(count) {
      const badge = document.getElementById('notificationBadge');
      if (count > 0) {
        badge.textContent = count > 99 ? '99+' : count;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }

    // Mark single notification as read
    async function markNotificationRead(notificationId) {
      try {
        const response = await fetch(`${API_URL}/notifications/${notificationId}/read`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (response.ok) {
          loadNotifications();
        }
      } catch (error) {
        console.error('Error marking notification as read:', error);
      }
    }

    // Clear all notifications (mark as read)
    async function clearAllNotifications() {
      try {
        const response = await fetch(`${API_URL}/notifications/user/${user.id}/read-all`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (response.ok) {
          loadNotifications();
        }
      } catch (error) {
        console.error('Error clearing notifications:', error);
      }
    }

    // Load unread count on page load
    function loadUnreadCount() {
      fetch(`${API_URL}/notifications/user/${user.id}?unread_only=true`, {
        headers: {
          'Content-Type': 'application/json'
        }
      })
        .then(res => res.json())
        .then(data => {
          updateNotificationBadge(data.unread_count || 0);
        })
        .catch(err => console.error('Error loading unread count:', err));
    }

    // Refresh notifications every 30 seconds
    setInterval(() => {
      if (!notificationsOpen) {
        loadUnreadCount();
      }
    }, 30000);

    // Load orders from backend API
    async function loadOrders() {
      let userBookings = [];
      const container = document.getElementById('ordersContainer');

      try {
        const res = await fetch(`${API_URL}/bookings/customer/${user.id}`, {
          headers: { 'Content-Type': 'application/json' }
        });

        if (!res.ok) {
          throw new Error('Failed to load bookings');
        }

        const data = await res.json();
        userBookings = data.bookings || [];
      } catch (error) {
        container.innerHTML = `
          <div class="empty-state">
            <h3>Unable to Load Bookings</h3>
            <p>Please refresh the page and try again.</p>
            <a href="booking.html">Book Now</a>
          </div>
        `;
        updateStats(0, 0, 0, 0);
        return;
      }

      if (userBookings.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <h3>No Bookings Yet</h3>
            <p>You haven't made any bookings yet. Start by booking a photographer for your event!</p>
            <a href="booking.html">Book Now</a>
          </div>
        `;
        updateStats(0, 0, 0, 0);
        return;
      }

      container.innerHTML = userBookings.map(booking => {
        const tokenAmount = Math.round((booking.token_amount || 0));
        const remainingAmount = Math.round((booking.remaining_amount || 0));
        const totalAmount = Math.round((booking.total_price || 0));
        const eventDate = booking.event_date ? new Date(booking.event_date).toLocaleDateString('en-IN') : 'Not set';
        const photographerName = booking.photographer && booking.photographer.user
          ? `${booking.photographer.user.first_name} ${booking.photographer.user.last_name}`
          : 'Assigning...';
        const paymentStatusLabel = booking.payment_status === 'paid'
          ? 'Full Payment Received'
          : (booking.payment_status === 'token_paid' ? 'Token Paid' : 
             (booking.status === 'pending' ? 'Waiting for Photographer' : 'Pending Payment'));
        const canPayToken = booking.payment_status === 'pending' && booking.status === 'accepted';

        return `
        <div class="order-card" data-id="${booking.id}">
          <div class="order-header">
            <span class="order-id">#${booking.id}</span>
            <span class="order-status ${booking.status}">${booking.status.charAt(0).toUpperCase() + booking.status.slice(1)}</span>
          </div>
          <div class="order-details">
            <div class="detail-item">
              <label>Service Type</label>
              <span>${booking.service_type}</span>
            </div>
            <div class="detail-item">
              <label>Event Date</label>
              <span>${eventDate}</span>
            </div>
            <div class="detail-item">
              <label>Location</label>
              <span>${booking.location || 'Not specified'}</span>
            </div>
            <div class="detail-item">
              <label>Photographer</label>
              <span>${photographerName}</span>
            </div>
          </div>
          <div class="payment-section">
            <div class="payment-row">
              <span>Token Amount</span>
              <span>₹${tokenAmount.toLocaleString()}</span>
            </div>
            <div class="payment-row">
              <span>Remaining Amount</span>
              <span>₹${remainingAmount.toLocaleString()}</span>
            </div>
            <div class="payment-row total">
              <span>Total</span>
              <span>₹${totalAmount.toLocaleString()}</span>
            </div>
            <div style="margin-top: 15px;">
              <span class="payment-status ${booking.payment_status === 'paid' || booking.payment_status === 'token_paid' ? 'paid' : 'unpaid'}">
                ${paymentStatusLabel}
              </span>
            </div>
          </div>
          ${canPayToken ? `
            <button class="btn btn-pay" onclick="makePayment(${booking.id})">
              Pay Token ₹${tokenAmount.toLocaleString()}
            </button>
          ` : `
            <button class="btn btn-pay" style="opacity: 0.7; cursor: default" disabled>
              ${booking.payment_status === 'paid' ? '✓ Payment Complete' : 
                (booking.payment_status === 'token_paid' ? '✓ Token Paid' : 
                  (booking.status === 'pending' ? '⏳ Waiting for Photographer' : '✓ Token Paid'))}
            </button>
          `}
        </div>
      `}).join('');

      // Update stats
      const pending = userBookings.filter(b => b.status === 'new' || b.status === 'pending').length;
      const active = userBookings.filter(b => b.status === 'accepted' || b.status === 'token_paid').length;
      const completed = userBookings.filter(b => b.status === 'completed').length;
      const totalSpent = userBookings
        .filter(b => b.payment_status === 'paid' || b.payment_status === 'token_paid')
        .reduce((sum, b) => sum + Math.round(b.total_price || 0), 0);

      updateStats(pending, active, completed, totalSpent);
    }

    function updateStats(pending, active, completed, totalSpent) {
      document.getElementById('pendingCount').textContent = pending;
      document.getElementById('activeCount').textContent = active;
      document.getElementById('completedCount').textContent = completed;
      document.getElementById('totalSpent').textContent = '₹' + totalSpent.toLocaleString();
    }

    async function makePayment(bookingId) {
      try {
        // First try Razorpay order creation
        const orderRes = await fetch(`${API_URL}/payment/create-order`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            booking_id: bookingId,
            customer_id: user.id
          })
        });

        const orderData = await orderRes.json();

        // If Razorpay is not configured, fall back to offline/demo payment
        if (!orderRes.ok) {
          if (orderData.error && orderData.error.includes('Razorpay is not configured')) {
            // Offer offline/demo payment
            const result = await Swal.fire({
              icon: 'info',
              title: 'Pay Token Amount',
              html: 'Online payment gateway is not configured.<br>Process token payment in <b>demo mode</b>?',
              showCancelButton: true,
              confirmButtonText: 'Pay Now (Demo)',
              confirmButtonColor: '#10b981'
            });
            if (!result.isConfirmed) return;

            const offlineRes = await fetch(`${API_URL}/payment/pay-token-offline`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ booking_id: bookingId, customer_id: user.id })
            });
            const offlineData = await offlineRes.json();
            if (!offlineRes.ok) {
              Swal.fire({ icon: 'error', title: 'Payment Error', text: offlineData.error || 'Payment failed' });
              return;
            }
            Swal.fire({ icon: 'success', title: 'Payment Successful!', text: 'Token payment completed. Your booking is now confirmed.', confirmButtonColor: '#10b981' });
            loadOrders();
            loadUnreadCount();
            return;
          }

          Swal.fire({
            icon: 'error',
            title: 'Payment Error',
            text: orderData.error || 'Unable to create payment order'
          });
          return;
        }

        // Razorpay is available — open checkout
        const options = {
          key: orderData.key_id,
          amount: orderData.amount,
          currency: 'INR',
          name: 'BookMyShoot',
          description: 'Booking Token Payment',
          order_id: orderData.order_id,
          handler: async function (response) {
            const verifyRes = await fetch(`${API_URL}/payment/verify`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                booking_id: bookingId,
                customer_id: user.id,
                razorpay_order_id: response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature: response.razorpay_signature
              })
            });

            const verifyData = await verifyRes.json();
            if (verifyRes.ok && verifyData.status === 'success') {
              Swal.fire({
                icon: 'success',
                title: 'Payment Successful',
                text: 'Token payment successful! Your booking is now confirmed.'
              });
              loadOrders();
              return;
            }
            Swal.fire({
              icon: 'error',
              title: 'Verification Failed',
              text: verifyData.error || 'Payment verification failed'
            });
          },
          prefill: {
            name: orderData.customer_name || '',
            email: orderData.customer_email || ''
          },
          theme: {
            color: '#10b981'
          }
        };

        const razorpayCheckout = new Razorpay(options);
        razorpayCheckout.open();
      } catch (error) {
        console.error('Payment error:', error);
        Swal.fire({
          icon: 'error',
          title: 'System Error',
          text: 'Unable to start payment. Please try again later.'
        });
      }
    }

    function logout() {
      localStorage.removeItem('user');
      window.location.href = 'index.html';
    }

    // Load on page load
    loadOrders();
    loadUnreadCount();
  </script>
</body>

</html>